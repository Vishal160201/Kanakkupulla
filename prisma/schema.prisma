generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id        String    @id @default(cuid())
  name      String
  phone     String
  email     String?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
}

model Order {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id])
  package      Float    @default(0)
  advance      Float    @default(0)
  due          Float    @default(0)
  installments Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Booking {
  id            String        @id @default(cuid())
  bookingNumber String?       @unique
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  category      String        @default("Wedding")
  date          DateTime
  time          String
  location      String
  status        String        @default("Confirmed") // "Confirmed" | "Pending" | "Partial"
  galleryUrl    String?       @db.Text
  contractUrl   String?       @db.Text
  customData    Json? // Stores dynamic form fields
  packageName   String?
  inclusions    Json? // Array of inclusion strings
  notes         String?       @db.Text
  attachments   Json? // Array of attachment objects/urls
  photographers Json? // Array of user IDs assigned
  deletedAt     DateTime? // Soft delete flag
  order         Order?
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById   String?
  createdBy     User?         @relation("BookingCreatedBy", fields: [createdById], references: [id])
  updatedById   String?
  updatedBy     User?         @relation("BookingUpdatedBy", fields: [updatedById], references: [id])

  @@index([date])
  @@index([clientId])
  @@index([deletedAt])
  @@index([status])
  @@index([deletedAt, date])
  @@index([clientId, date])
}

model SystemLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())
}

model Transaction {
  id            String   @id @default(cuid())
  transactionId String?  @unique
  amount        Float
  type          String // "INCOME" | "EXPENSE"
  date          DateTime
  category      String
  paymentMode   String
  description   String?  @db.Text
  status        String   @default("SETTLED") // "SETTLED" | "PENDING"
  attachmentUrl String?  @db.Text
  customData    Json? // Stores dynamic form fields
  bookingId     String?
  booking       Booking? @relation(fields: [bookingId], references: [id])
  productOrderId String?
  productOrder  ProductOrder? @relation(fields: [productOrderId], references: [id])
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([date])
  @@index([category])
  @@index([type])
  @@index([paymentMode])
  @@index([userId])
  @@index([date, type])
  @@index([userId, date])
  @@index([transactionId])
  @@index([productOrderId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  STAFF
  PHOTOGRAPHER
}

enum UserStatus {
  ACTIVE
  PENDING
  INACTIVE
}

model User {
  id                 String             @id @default(cuid())
  idNumber           Int                @default(autoincrement())
  name               String?
  email              String?            @unique
  emailVerified      DateTime?
  password           String?
  image              String?
  role               Role               @default(STAFF)
  status             UserStatus         @default(ACTIVE)
  invitedAt          DateTime?
  accounts           Account[]
  sessions           Session[]
  transactions       Transaction[]
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
  emailNotifications Boolean            @default(true)
  pushNotifications  Boolean            @default(true)
  phone              String?
  whatsappNotifs     Boolean            @default(false)
  createdBookings    Booking[]          @relation("BookingCreatedBy")
  updatedBookings    Booking[]          @relation("BookingUpdatedBy")

  @@index([status])
}

model RolePermission {
  id         String  @id @default(cuid())
  role       Role
  permission String
  enabled    Boolean @default(false)

  @@unique([role, permission])
  @@index([role])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Product {
  id          String         @id @default(cuid())
  name        String
  description String?        @db.Text
  price       Float
  stock       Int            @default(0)
  orders      ProductOrder[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([createdAt])
}

model ProductOrder {
  id          String   @id @default(cuid())
  orderNumber String?  @unique
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      @default(1)
  status      String   @default("PENDING") // "PENDING" | "PROCESSING" | "SHIPPED" | "DELIVERED" | "READY"
  clientName  String
  clientPhone String?
  dueDate     DateTime?
  customData  Json?    // Specific details based on product
  transactions Transaction[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormLayout {
  id          String   @id @default(cuid())
  formKey     String   @unique // e.g., "BOOKING_FORM", "TRANSACTION_FORM"
  name        String
  description String?
  schema      Json // Stores sections, fields, types, and mandatory rules
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // e.g., "BOOKING", "PAYMENT", "SYSTEM", "ALERT"
  title     String
  message   String   @db.Text
  link      String? // Optional URL to navigate to when clicked
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model RecycleBin {
  id           String   @id @default(cuid())
  itemType     String
  itemId       String
  originalData Json
  trashedById  String?
  trashedAt    DateTime @default(now())

  @@index([itemType])
  @@index([trashedAt])
}
